{
  "name": "@pearl/pearl-address-validation",
  "version": "3.0.0",
  "description": "Validate Pearl P2TR (witness v1) and P2MR (witness v2) addresses using bech32m encoding for mainnet, testnet, and simnet networks.",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-format": "prettier --check src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "lint": "tsc --noEmit",
    "ci": "pnpm run build && pnpm run check-format && pnpm run check-exports && pnpm run lint && pnpm run test",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "pnpm run ci"
  },
  "keywords": [
    "address",
    "pearl",
    "pearl-research-labs",
    "validation",
    "mainnet",
    "testnet",
    "simnet",
    "bech32m",
    "taproot",
    "p2tr",
    "witness-v1",
    "p2mr",
    "witness-v2"
  ],
  "author": {
    "name": "Liad Madmon",
    "email": "liad.madmon@pearlresearch.ai",
    "url": "https://pearlresearch.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pearl-research-labs/pearl/apps/packages/pearl-address-validation"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.3",
    "@changesets/cli": "^2.27.12",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "bech32": "^2.0.0"
  }
}
